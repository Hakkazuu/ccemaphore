    "settings.hooks.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Installiert Claude-Code-Hooks, die das Ende eines Zugs und das Warten auf Eingaben präzise erkennen – zuverlässiger als über die Dateien."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Installs Claude Code hooks that detect turn completion and waiting-for-input precisely — more reliably than reading the files."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Instala los hooks de Claude Code que detectan el fin del turno y la espera de entrada con precisión, más fiable que por los archivos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Installe les hooks de Claude Code qui détectent précisément la fin du tour et l'attente d'une saisie — plus fiable que par les fichiers."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Устанавливает хуки Claude Code: точно определяют завершение хода и ожидание ввода — надёжнее, чем по файлам."
          }
        }
      }
    },
