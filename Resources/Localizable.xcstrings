    "settings.idelog.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Liest das Log der Cursor/VS-Code-Erweiterung, um das Berechtigungsband sofort auszublenden, wenn du in der IDE antwortest (nicht erst nach Befehlsende). Undokumentiertes IDE-Log – kann bei IDE-Updates brechen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reads the Cursor/VS Code extension log to drop the permission ribbon the moment you answer in the IDE (not when the command finishes). Undocumented IDE log — may break on IDE updates."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee el registro de la extensión de Cursor/VS Code para quitar la solicitud en cuanto respondes en el IDE (no al terminar el comando). Registro interno del IDE: puede romperse al actualizar el IDE."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Lit le journal de l’extension Cursor/VS Code pour masquer la demande dès que vous répondez dans l’IDE (et non à la fin de la commande). Journal interne de l’IDE — peut casser lors des mises à jour de l’IDE."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Читает лог расширения Cursor/VS Code, чтобы убрать ленту разрешения сразу после вашего ответа в IDE (а не по завершении команды). Внутренний лог IDE — может сломаться на обновлении IDE."
          }
        }
      }
    },
