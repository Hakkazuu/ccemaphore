    "error.settings.unexpectedShape": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Unerwartete Struktur in settings.json (%@) – Abbruch, damit deine Daten nicht verloren gehen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unexpected structure in settings.json (%@) — aborting so your data isn't lost."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Estructura inesperada en settings.json (%@): se cancela para no perder tus datos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Structure inattendue dans settings.json (%@) — abandon pour ne pas perdre vos données."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Неожиданная структура в settings.json (%@) — прерываю, чтобы не потерять ваши данные."
          }
        }
      }
    },
    "error.settings.unparseable": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ existiert, ist aber kein gültiges JSON. Die Datei bleibt unangetastet, damit sie nicht beschädigt wird – behebe sie und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ exists but isn't valid JSON. Leaving it untouched so it isn't corrupted — fix the file and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ existe pero no es un JSON válido. Se deja intacto para no corromperlo: corrige el archivo e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ existe mais n'est pas un JSON valide. Le fichier est laissé intact pour ne pas le corrompre — corrigez-le et réessayez."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Файл %@ существует, но это невалидный JSON. Оставляю его нетронутым, чтобы не повредить — исправьте файл и попробуйте снова."
          }
        }
      }
    },
