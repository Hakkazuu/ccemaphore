    "history.footer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Verlauf reicht nur so weit zurück wie die Einstellung „cleanupPeriodDays“ von Claude Code – derzeit %@. Claude Code entfernt alte Transkripte selbst; erhöhe das Limit, um sie länger zu behalten."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "History reaches back only as far as Claude Code's “cleanupPeriodDays” setting — currently %@. Claude Code removes old transcripts on its own; raise the limit to keep them longer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El historial solo se remonta hasta el ajuste «cleanupPeriodDays» de Claude Code: actualmente %@. Claude Code elimina las transcripciones antiguas por su cuenta; aumenta el límite para conservarlas más tiempo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'historique ne remonte que jusqu'à la valeur du réglage « cleanupPeriodDays » de Claude Code — actuellement %@. Claude Code supprime lui-même les anciennes transcriptions ; augmentez la limite pour les conserver plus longtemps."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История доступна только в пределах настройки «cleanupPeriodDays» в Claude Code — сейчас %@. Claude Code сам удаляет старые транскрипты; увеличьте значение, чтобы хранить их дольше."
          }
        }
      }
    },
