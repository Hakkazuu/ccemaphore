    "history.detail.carryOver": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Tokens dieses Tages (%@) gehören zu einem Chat, der später fortgesetzt wurde – er erscheint unter dem Tag seiner letzten Aktivität."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This day's tokens (%@) belong to a chat that continued later — it's shown under the day of its last activity."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los tokens de este día (%@) pertenecen a un chat que continuó más tarde: se muestra en el día de su última actividad."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les tokens de ce jour (%@) appartiennent à un chat qui s'est poursuivi plus tard — il est affiché sous le jour de sa dernière activité."
