    "settings.trusted.explainer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Von ccemaphore automatisch genehmigt – keine Berechtigungsabfrage. Abgleich als Teilzeichenfolge des Befehls."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-approved by ccemaphore — no permission prompt appears. Matched as a substring of the command."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "ccemaphore los aprueba automáticamente: no aparece ninguna solicitud de permiso. Coincidencia por subcadena del comando."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Approuvées automatiquement par ccemaphore — aucune demande d’autorisation. Correspondance par sous-chaîne de la commande."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "ccemaphore одобряет их автоматически — запрос разрешения не появляется. Совпадение по подстроке команды."
          }
        }
      }
    },
